---
// Qui puoi inserire JavaScript che verrà eseguito solo durante la fase di build (non nel browser!)
const nomeScuola = "Autoscuola Sprint";
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{nomeScuola} - La tua patente facile</title>
    <style>
      body { font-family: Arial, sans-serif; line-height: 1.6; margin: 0; padding: 20px; background-color: #f4f4f9; }
      header { background: #ff4500; color: white; padding: 20px; text-align: center; border-radius: 8px; }
      .servizi { display: flex; gap: 20px; margin-top: 20px; }
      .card { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); flex: 1; }
    </style>
  </head>
  <body>
    <header>
      <h1>Benvenuti all'{nomeScuola}!</h1>
      <p>Mettiti alla guida del tuo futuro.</p>
    </header>

    <div class="servizi">
      <div class="card">
        <h2>Patente B</h2>
        <p>Corsi teorici e pratici per il conseguimento della patente auto. Istruttori qualificati e veicoli moderni.</p>
      </div>
      <div class="card">
        <h2>Patente A</h2>
        <p>Senti la libertà su due ruote. Preparazione completa per tutte le categorie di moto.</p>
      </div>
    </div>
  </body>
</html>
